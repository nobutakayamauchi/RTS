{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nobutakayamauchi/RTS/freezer/schemas/item.schema.json",
  "title": "RTS FREEZER Item",
  "type": "object",
  "required": [
    "item_id",
    "version",
    "title",
    "type",
    "status",
    "summary",
    "original_problem",
    "why_it_matters",
    "reason_frozen",
    "preserved_value",
    "priority",
    "trigger_conditions",
    "negative_triggers",
    "dependencies",
    "source_refs",
    "possible_destinations",
    "estimated_hours",
    "tags",
    "build_authority",
    "recall_mode",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "item_id": {
      "type": "string",
      "pattern": "^RTS-FRZ-[0-9]{6}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": [
        "feature",
        "research",
        "product",
        "architecture",
        "process",
        "risk"
      ]
    },
    "status": {
      "enum": [
        "CAPTURED",
        "NORMALIZED",
        "SCORED",
        "READY",
        "SELECTED",
        "IN_PROGRESS",
        "VERIFIED",
        "COMPLETED",
        "BLOCKED",
        "FROZEN",
        "RESEARCH_REQUIRED",
        "REJECTED"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "original_problem": {
      "type": "string",
      "minLength": 1
    },
    "why_it_matters": {
      "type": "string",
      "minLength": 1
    },
    "reason_frozen": {
      "type": "string"
    },
    "preserved_value": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "object",
      "required": [
        "impact",
        "urgency",
        "strategic_fit",
        "readiness",
        "revenue_value",
        "dependency_value",
        "risk_reduction",
        "confidence",
        "effort",
        "uncertainty"
      ],
      "additionalProperties": false,
      "properties": {
        "impact": {"type": "number", "minimum": 0, "maximum": 5},
        "urgency": {"type": "number", "minimum": 0, "maximum": 5},
        "strategic_fit": {"type": "number", "minimum": 0, "maximum": 5},
        "readiness": {"type": "number", "minimum": 0, "maximum": 5},
        "revenue_value": {"type": "number", "minimum": 0, "maximum": 5},
        "dependency_value": {"type": "number", "minimum": 0, "maximum": 5},
        "risk_reduction": {"type": "number", "minimum": 0, "maximum": 5},
        "confidence": {"type": "number", "minimum": 0, "maximum": 5},
        "effort": {"type": "number", "minimum": 0, "maximum": 5},
        "uncertainty": {"type": "number", "minimum": 0, "maximum": 5}
      }
    },
    "trigger_conditions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "negative_triggers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "possible_destinations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "estimated_hours": {
      "type": "object",
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": {"type": "number", "minimum": 0},
        "maximum": {"type": "number", "minimum": 0}
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "build_authority": {
      "enum": ["NOT_APPROVED", "APPROVED"]
    },
    "recall_mode": {
      "enum": ["MANUAL", "CONDITION_WATCH"]
    },
    "supersedes": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
