{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nobutakayamauchi/RTS/loop_core/schemas/evaluation.schema.json",
  "title": "RTS Read-Only Loop Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "as_of",
    "authority",
    "implementation_authority_granted",
    "inputs",
    "wip",
    "state",
    "audit_level",
    "evidence",
    "recommendation"
  ],
  "properties": {
    "schema_version": {"const": "RTS-LOOP-EVALUATION-V1"},
    "evaluation_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "as_of": {"type": "string", "minLength": 1},
    "authority": {"const": "ADVISORY_ONLY"},
    "implementation_authority_granted": {"const": false},
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "wip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "active_item_ids"],
      "properties": {
        "count": {"type": "integer", "minimum": 0},
        "active_item_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "state": {"enum": ["NORMAL", "FOCUS", "OVERLOAD", "STALL", "BLOCKED"]},
    "audit_level": {"enum": ["NORMAL", "WARNING", "RISK", "CRITICAL"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified", "unverified", "assumed"],
      "properties": {
        "verified": {"type": "array", "items": {"type": "string"}},
        "unverified": {"type": "array", "items": {"type": "string"}},
        "assumed": {"type": "array", "items": {"type": "string"}}
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "item_id", "why", "success_condition", "fallback", "stop_conditions"],
      "properties": {
        "action": {"type": "string", "minLength": 1},
        "item_id": {"type": ["string", "null"]},
        "why": {"type": "string", "minLength": 1},
        "success_condition": {"type": "string", "minLength": 1},
        "fallback": {"type": "string", "minLength": 1},
        "stop_conditions": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
